# ---- Application ----
APP_NAME=IWX-EarnLens
APP_ENV=development
DEBUG=true
API_PREFIX=/api
VERSION=1.0.0

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Database ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=iwx_earnlens

# ---- Security / JWT ----
# Generate strong secrets, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
JWT_SECRET_KEY=change-me-in-production-please
JWT_REFRESH_SECRET_KEY=change-me-too-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30
EMAIL_VERIFY_EXPIRE_HOURS=48

# ---- CORS (comma-separated) ----
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:12056,http://127.0.0.1:12056

# ---- Defaults ----
DEFAULT_CURRENCY=USD
